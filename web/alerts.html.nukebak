<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Alerts — AgoraIQ Signals</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Mono:wght@400;500&family=Albert+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* === ACCENT COLOR === */
h1 .accent { color: #FCD535 !important; }

/* === FORCE H1 STYLE === */
h1, h2, h3, h4, h5, h6 {
  font-family: 'Albert Sans', sans-serif !important;
}
h1 {
  font-family: 'Albert Sans', sans-serif !important;
  font-weight: 900 !important;
  font-size: clamp(34px, 4.5vw, 48px) !important;
  letter-spacing: -2px !important;
  text-transform: uppercase !important;
  color: #e2e4ef !important;
  line-height: 1.08 !important;
}
h1 .accent {
  color: #EFBF04 !important;
}


h1 .accent { color: #FCD535 !important; }

h1, h2, h3, h4, h5, h6 {
  font-family: 'Albert Sans', sans-serif !important;
}
h1 {
  font-family: 'Albert Sans', sans-serif !important;
  font-weight: 900 !important;
  font-size: clamp(34px, 4.5vw, 48px) !important;
  letter-spacing: -2px !important;
  text-transform: uppercase !important;
  color: #EFBF04 !important;
  line-height: 1.08 !important;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#08090d;--surface:#0e1017;--surface2:#161822;--border:#1e2230;--cyan:#00d4ff;--cyan-dim:rgba(0,212,255,.12);--cyan-glow:rgba(0,212,255,.25);--green:#22c55e;--red:#ef4444;--amber:#f59e0b;--text:#e4e7ef;--text2:#8b92a8;--syne:'Syne',sans-serif;--mono:'DM Mono',monospace;--sans:'Albert Sans',sans-serif}
html{background:var(--bg);color:var(--text);font-family:var(--mono);font-size:14px;-webkit-font-smoothing:antialiased}
body{min-height:100vh}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:16px 24px;border-bottom:1px solid var(--border);background:var(--surface)}
.brand{display:flex;align-items:center;gap:8px;text-decoration:none}
.brand-mark{width:28px;height:28px;background:linear-gradient(135deg,#55d0ff,#1a6eff);clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);flex-shrink:0}
.brand-text{font-family:var(--syne,'Syne',sans-serif);font-weight:800;font-size:18px;color:#fff;letter-spacing:-.02em}
.brand-iq{color:var(--cyan,#00d4ff)}
.topbar nav{display:flex;gap:20px}
.topbar nav a{color:var(--text2);text-decoration:none;font-size:13px;transition:color .2s}
.topbar nav a:hover,.topbar nav a.active{color:var(--cyan)}
.container{max-width:1080px;margin:0 auto;padding:32px 24px}
h1{/* inherited from styles.css */ font-weight:800;font-size:28px;margin-bottom:8px;background:linear-gradient(135deg,#fff 40%,var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.subtitle{color:var(--text2);font-size:13px;margin-bottom:32px}
.badge{display:inline-block;padding:3px 8px;border-radius:4px;font-size:11px;font-weight:600;font-family:var(--sans);text-transform:uppercase}
.badge-open{background:var(--cyan-dim);color:var(--cyan)}
.badge-tp{background:rgba(34,197,94,.12);color:var(--green)}
.badge-sl{background:rgba(239,68,68,.12);color:var(--red)}
.badge-expired{background:rgba(245,158,11,.12);color:var(--amber)}
.badge-cancelled{background:rgba(139,146,168,.12);color:var(--text2)}
.dir-long{color:var(--green)}.dir-short{color:var(--red)}
table{width:100%;border-collapse:collapse}
th{font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--text2);text-align:left;padding:10px 12px;border-bottom:1px solid var(--border);font-weight:500}
td{padding:10px 12px;border-bottom:1px solid var(--border);font-size:13px}
tr:hover td{background:var(--surface2)}
.tabs{display:flex;gap:6px;margin-bottom:24px;flex-wrap:wrap}
.tab{padding:8px 16px;border-radius:20px;font-size:12px;font-family:var(--mono);border:1px solid var(--border);color:var(--text2);background:transparent;cursor:pointer;transition:all .15s}
.tab:hover{border-color:var(--cyan);color:var(--cyan)}
.tab.active{background:var(--cyan-dim);border-color:var(--cyan);color:var(--cyan)}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px}
.card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px;transition:border-color .2s}
.card:hover{border-color:rgba(0,212,255,.3)}
.card-sym{font-family:var(--syne);font-weight:700;font-size:16px;color:#fff;margin-bottom:8px}
.card-row{display:flex;justify-content:space-between;font-size:12px;color:var(--text2);margin-bottom:4px}
.card-row .v{color:var(--text);font-family:var(--sans);font-weight:600}
.card-row .v.g{color:var(--green)}.card-row .v.r{color:var(--red)}
.bar-bg{height:4px;background:var(--surface2);border-radius:2px;margin-top:8px;overflow:hidden}
.bar-fg{height:100%;border-radius:2px;background:var(--cyan);transition:width .4s}
.empty{text-align:center;padding:48px;color:var(--text2)}
.stat-strip{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:32px}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px 20px}
.stat-label{font-size:11px;color:var(--text2);text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px}
.stat-value{font-family:var(--sans);font-weight:700;font-size:22px;color:#fff}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border:none;border-radius:6px;font-family:var(--sans);font-weight:600;font-size:13px;cursor:pointer;transition:all .2s;text-decoration:none}
.btn-primary{background:var(--cyan);color:#000}.btn-primary:hover{background:#33ddff}
.btn-ghost{background:transparent;border:1px solid var(--border);color:var(--text2)}.btn-ghost:hover{border-color:var(--cyan);color:var(--cyan)}
.locked{color:var(--text2);opacity:.4;font-style:italic}
.upgrade-bar{background:rgba(0,212,255,.06);border:1px solid rgba(0,212,255,.15);border-radius:10px;padding:14px 20px;margin-top:16px;font-size:13px;color:var(--text2);display:none;text-align:center}
.upgrade-bar a{color:var(--cyan);text-decoration:none;font-weight:600}
.auth-bar{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:16px 20px;margin-bottom:24px;display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap}
.auth-bar p{color:var(--text2);font-size:13px;margin:0}
.auth-bar .actions{display:flex;gap:10px}
@media(max-width:640px){.container{padding:20px 16px}table{display:block;overflow-x:auto}.grid{grid-template-columns:1fr}.auth-bar{flex-direction:column;text-align:center}}
.legal-footer{background:var(--surface,#0e1017);border-top:1px solid var(--border,#1e2230);padding:32px 24px;margin-top:48px;text-align:center;font-size:12px;font-family:var(--sans,'Albert Sans',sans-serif);color:var(--text2,#8b92a8)}
.footer-inner{max-width:860px;margin:0 auto}
.footer-brand{font-family:var(--syne,'Syne',sans-serif);font-weight:800;font-size:16px;color:var(--cyan,#00d4ff);margin-bottom:12px}
.footer-links{display:flex;flex-wrap:wrap;justify-content:center;gap:16px;margin-bottom:12px}
.footer-links a{color:var(--text2,#8b92a8);text-decoration:none;transition:color .2s}
.footer-links a:hover{color:var(--cyan,#00d4ff)}
.footer-copy{margin-bottom:8px}
.footer-warn{font-size:11px;color:var(--text2,#8b92a8);opacity:.7;max-width:640px;margin:0 auto;line-height:1.5}
</style>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/styles.css">
</head>
<body>
<div class="topbar"><a href="/" class="brand"><span class="brand-mark" aria-hidden="true"></span><span class="brand-text">Agora<span class="brand-iq">IQ</span></span></a><nav><a href="signals.html">Signals</a><a href="scanner.html">Scanner</a><a href="track.html">Track</a><a href="proof.html">Proof</a><a href="providers.html">Providers</a><a href="pricing.html">Pricing</a><a href="watchlist.html">Watchlist</a><a href="help.html">Help</a></nav></div>
<div class="container">
  <h1>Smart <span class="accent">Alerts</span></h1>
  <p class="subtitle">Custom alert rules — get notified when market conditions match your criteria</p>
  
  <div class="auth-bar" id="authBar">
    <p>Smart Alerts require a Pro or Elite plan. <a href="pricing.html" style="color:var(--cyan)">Upgrade</a></p>
    <div class="actions" id="authActions"></div>
  </div>
  <div id="rulesList"></div>
  <div class="empty" id="empty" style="display:none">No alert rules configured. Use the Telegram bot <code style="font-family:var(--mono);color:var(--cyan)">/addalert BTCUSDT</code> to create one.</div>

</div>
<script>
(function(){
  "use strict";
  var API="/api/v1",token=localStorage.getItem("iq_token");
  function el(t,c,x){var n=document.createElement(t);if(c)n.className=c;if(x!=null)n.textContent=String(x);return n}

  document.addEventListener("DOMContentLoaded",function(){
    if(!token){document.getElementById("empty").style.display="block";return}
    document.getElementById("authBar").style.display="none";
    fetch(API+"/alerts/rules",{headers:{"Authorization":"Bearer "+token}})
      .then(function(r){return r.ok?r.json():null}).then(function(d){
        if(!d){document.getElementById("empty").style.display="block";return}
        var rules=Array.isArray(d)?d:(d.rules||[]);
        if(!rules.length){document.getElementById("empty").style.display="block";return}
        var container=document.getElementById("rulesList");
        for(var i=0;i<rules.length;i++){
          var r=rules[i],c=el("div","card");c.style.marginBottom="8px";
          c.appendChild(el("div","card-sym",(r.name||r.symbol||"Alert #"+r.id)));
          var r1=el("div","card-row");r1.appendChild(el("span",null,"Type"));r1.appendChild(el("span","v",r.type||"—"));c.appendChild(r1);
          var r2=el("div","card-row");r2.appendChild(el("span",null,"Enabled"));r2.appendChild(el("span","v "+(r.enabled?"g":"r"),r.enabled?"Yes":"No"));c.appendChild(r2);
          container.appendChild(c)
        }
      }).catch(function(){document.getElementById("empty").style.display="block"});
  });
})();
</script>
<footer class="legal-footer">
  <div class="footer-inner">
    <div class="footer-brand">Agora<span style="color:var(--cyan,#00d4ff)">IQ</span></div>
    <div class="footer-links">
      <a href="terms.html">Terms</a>
      <a href="privacy.html">Privacy</a>
      <a href="cookies.html">Cookies</a>
      <a href="disclaimer.html">Disclaimer</a>
      <a href="no-financial-advice.html">No Financial Advice</a>
    </div>
    <div class="footer-copy">&copy; 2026 ChatLogic Insights LTD. All rights reserved.</div>
    <div class="footer-warn">&olarr; Not for UK Persons. AgoraIQ is not authorised or regulated by the FCA. Not directed at UK persons. Nothing on this site constitutes financial advice. Past performance does not guarantee future results.</div>
  </div>
</footer>
</body>
</html>
