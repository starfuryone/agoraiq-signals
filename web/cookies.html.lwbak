<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cookie Policy — AgoraIQ Signals</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Mono:wght@400;500&family=Albert+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* === FORCE H1 STYLE === */
h1, h2, h3, h4, h5, h6 {
  font-family: 'Albert Sans', sans-serif !important;
}
h1 {
  font-family: 'Albert Sans', sans-serif !important;
  font-weight: 900 !important;
  font-size: clamp(34px, 4.5vw, 48px) !important;
  letter-spacing: -2px !important;
  text-transform: uppercase !important;
  color: #EFBF04 !important;
  line-height: 1.08 !important;
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#08090d;--surface:#0e1017;--surface2:#161822;--border:#1e2230;--cyan:#00d4ff;--cyan-dim:rgba(0,212,255,.12);--green:#22c55e;--red:#ef4444;--amber:#f59e0b;--text:#e4e7ef;--text2:#8b92a8;--text3:#5b6178;--syne:'Syne',sans-serif;--mono:'DM Mono',monospace;--sans:'Albert Sans',sans-serif}
html{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:15px;-webkit-font-smoothing:antialiased}
body{min-height:100vh}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:16px 24px;border-bottom:1px solid var(--border);background:var(--surface)}
.brand{display:flex;align-items:center;gap:8px;text-decoration:none}
.brand-mark{width:28px;height:28px;background:linear-gradient(135deg,#55d0ff,#1a6eff);clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);flex-shrink:0}
.brand-text{font-family:var(--syne,'Syne',sans-serif);font-weight:800;font-size:18px;color:#fff;letter-spacing:-.02em}
.brand-iq{color:var(--cyan,#00d4ff)}
.topbar nav{display:flex;gap:20px}
.topbar nav a{color:var(--text2);text-decoration:none;font-size:13px;font-family:var(--mono);transition:color .2s}
.topbar nav a:hover{color:var(--cyan)}
.container{max-width:760px;margin:0 auto;padding:40px 24px 60px}
.breadcrumb{font-size:13px;color:var(--text3);margin-bottom:24px}
.breadcrumb a{color:var(--text2);text-decoration:none}
.breadcrumb a:hover{color:var(--cyan)}
h1{/* inherited from styles.css */ font-weight:800;font-size:32px;margin-bottom:8px;background:linear-gradient(135deg,#fff 40%,var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.updated{color:var(--text3);font-size:13px;margin-bottom:32px}
h2{/* inherited from styles.css */ font-weight:700;font-size:18px;color:#fff;margin:32px 0 12px;padding-top:20px;border-top:1px solid var(--border)}
h2:first-of-type{border-top:none;margin-top:24px}
p{color:var(--text);line-height:1.7;margin-bottom:14px}
ul,ol{margin:0 0 14px 24px;line-height:1.7}
li{margin-bottom:6px}
strong{color:#fff}
a{color:var(--cyan);text-decoration:none}
a:hover{text-decoration:underline}
.callout{background:var(--surface);border-left:3px solid var(--amber);padding:14px 18px;border-radius:0 8px 8px 0;margin:16px 0;font-size:14px;color:var(--text)}

.legal-footer{background:var(--surface,#0e1017);border-top:1px solid var(--border,#1e2230);padding:32px 24px;margin-top:48px;text-align:center;font-size:12px;font-family:var(--sans,'Albert Sans',sans-serif);color:var(--text2,#8b92a8)}
.footer-inner{max-width:860px;margin:0 auto}
.footer-brand{font-family:var(--syne,'Syne',sans-serif);font-weight:800;font-size:16px;color:var(--cyan,#00d4ff);margin-bottom:12px}
.footer-links{display:flex;flex-wrap:wrap;justify-content:center;gap:16px;margin-bottom:12px}
.footer-links a{color:var(--text2,#8b92a8);text-decoration:none;transition:color .2s}
.footer-links a:hover{color:var(--cyan,#00d4ff)}
.footer-copy{margin-bottom:8px}
.footer-warn{font-size:11px;color:var(--text2,#8b92a8);opacity:.7;max-width:640px;margin:0 auto;line-height:1.5}

@media(max-width:768px){.container{padding:24px 16px 40px}h1{font-size:26px}}
</style>
</head>
