<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Signal Feed — AgoraIQ Signals</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Mono:wght@400;500&family=Albert+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* === ACCENT COLOR === */
h1 .accent { color: #FCD535 !important; }

/* === FORCE H1 STYLE === */
h1, h2, h3, h4, h5, h6 {
  font-family: 'Albert Sans', sans-serif !important;
}
h1 {
  font-family: 'Albert Sans', sans-serif !important;
  font-weight: 900 !important;
  font-size: clamp(34px, 4.5vw, 48px) !important;
  letter-spacing: -2px !important;
  text-transform: uppercase !important;
  color: #e2e4ef !important;
  line-height: 1.08 !important;
}
h1 .accent {
  color: #EFBF04 !important;
}


h1 .accent { color: #FCD535 !important; }

h1, h2, h3, h4, h5, h6 {
  font-family: 'Albert Sans', sans-serif !important;
}
h1 {
  font-family: 'Albert Sans', sans-serif !important;
  font-weight: 900 !important;
  font-size: clamp(34px, 4.5vw, 48px) !important;
  letter-spacing: -2px !important;
  text-transform: uppercase !important;
  color: #EFBF04 !important;
  line-height: 1.08 !important;
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#08090d;--surface:#0e1017;--surface2:#161822;--border:#1e2230;
  --cyan:#00d4ff;--cyan-dim:rgba(0,212,255,.12);--cyan-glow:rgba(0,212,255,.25);
  --green:#22c55e;--red:#ef4444;--amber:#f59e0b;--purple:#a78bfa;
  --text:#e4e7ef;--text2:#8b92a8;
  --syne:'Syne',sans-serif;--mono:'DM Mono',monospace;--sans:'Albert Sans',sans-serif
}
html{background:var(--bg);color:var(--text);font-family:var(--mono);font-size:14px;-webkit-font-smoothing:antialiased}
body{min-height:100vh}

/* Topbar */
.topbar{display:flex;align-items:center;justify-content:space-between;padding:16px 24px;border-bottom:1px solid var(--border);background:var(--surface)}
.brand{display:flex;align-items:center;gap:8px;text-decoration:none}
.brand-mark{width:28px;height:28px;background:linear-gradient(135deg,#55d0ff,#1a6eff);clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);flex-shrink:0}
.brand-text{font-family:var(--syne);font-weight:800;font-size:18px;color:#fff;letter-spacing:-.02em}
.brand-iq{color:var(--cyan)}
.topbar nav{display:flex;gap:20px}
.topbar nav a{color:var(--text2);text-decoration:none;font-size:13px;transition:color .2s}
.topbar nav a:hover,.topbar nav a.active{color:var(--cyan)}

/* Layout */
.container{max-width:1200px;margin:0 auto;padding:32px 24px}
h1{/* inherited from styles.css */ font-weight:800;font-size:28px;margin-bottom:8px;background:linear-gradient(135deg,#fff 40%,var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.subtitle{color:var(--text2);font-size:13px;margin-bottom:32px}

/* Badges */
.badge{display:inline-block;padding:3px 8px;border-radius:4px;font-size:11px;font-weight:600;font-family:var(--sans);text-transform:uppercase;letter-spacing:.04em}
.badge-open{background:var(--cyan-dim);color:var(--cyan)}
.badge-tp{background:rgba(34,197,94,.12);color:var(--green)}
.badge-sl{background:rgba(239,68,68,.12);color:var(--red)}
.badge-expired{background:rgba(245,158,11,.12);color:var(--amber)}
.badge-cancelled{background:rgba(139,146,168,.12);color:var(--text2)}

/* Direction */
.dir-long{color:var(--green);font-weight:700}
.dir-short{color:var(--red);font-weight:700}

/* Table */
table{width:100%;border-collapse:collapse}
th{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--text2);text-align:left;padding:10px 12px;border-bottom:1px solid var(--border);font-weight:500;white-space:nowrap}
td{padding:10px 12px;border-bottom:1px solid var(--border);font-size:13px;vertical-align:middle}
tbody tr:hover td{background:rgba(255,255,255,.02);cursor:pointer}
.empty{text-align:center;padding:48px;color:var(--text2)}

/* Confidence label */
.conf-label{font-size:10px;text-transform:uppercase;letter-spacing:.06em;margin-top:3px;font-family:var(--sans);font-weight:700}
.conf-strong{color:var(--green)}.conf-good{color:var(--cyan)}.conf-speculative{color:var(--amber)}.conf-avoid{color:var(--red)}

/* Row tags */
.row-tags{display:flex;flex-wrap:wrap;gap:3px}
.row-tag{padding:2px 6px;border-radius:3px;font-size:10px;font-weight:700;font-family:var(--sans);text-transform:uppercase;letter-spacing:.02em}
.rt-breakout{background:rgba(0,212,255,.1);color:var(--cyan)}
.rt-volume{background:rgba(34,197,94,.1);color:var(--green)}
.rt-oi{background:rgba(167,139,250,.1);color:var(--purple)}
.rt-trend{background:rgba(245,158,11,.1);color:var(--amber)}
.rt-reversal{background:rgba(239,68,68,.1);color:var(--red)}
.rt-highrisk{background:rgba(239,68,68,.12);color:#f87171}
.rt-scalp{background:rgba(0,212,255,.08);color:#7dd3fc}
.rt-swing{background:rgba(167,139,250,.08);color:var(--purple)}

/* Open button */
.open-btn{background:transparent;border:1px solid var(--border);color:var(--text2);padding:5px 12px;border-radius:6px;font-size:11px;font-family:var(--mono);cursor:pointer;transition:all .15s;white-space:nowrap}
.open-btn:hover{border-color:var(--cyan);color:var(--cyan);background:var(--cyan-dim)}

/* Locked */
.locked{color:var(--text2);opacity:.35;font-style:italic;font-size:11px}

/* Auth / Upgrade */
.auth-bar{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px 20px;margin-bottom:24px;display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap}
.auth-bar p{color:var(--text2);font-size:13px;margin:0}
.auth-bar .actions{display:flex;gap:10px}
.upgrade-bar{background:rgba(0,212,255,.06);border:1px solid rgba(0,212,255,.15);border-radius:10px;padding:14px 20px;margin-top:16px;font-size:13px;color:var(--text2);display:none;text-align:center}
.upgrade-bar a{color:var(--cyan);text-decoration:none;font-weight:600}

/* Buttons */
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border:none;border-radius:6px;font-family:var(--sans);font-weight:600;font-size:13px;cursor:pointer;transition:all .2s;text-decoration:none}
.btn-primary{background:var(--cyan);color:#000}.btn-primary:hover{background:#33ddff}
.btn-ghost{background:transparent;border:1px solid var(--border);color:var(--text2)}.btn-ghost:hover{border-color:var(--cyan);color:var(--cyan)}

/* ====== DRAWER ====== */
.drawer-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(5px);-webkit-backdrop-filter:blur(5px);z-index:200;opacity:0;pointer-events:none;transition:opacity .25s}
.drawer-backdrop.open{opacity:1;pointer-events:all}
.drawer{position:fixed;top:0;right:0;height:100vh;width:min(540px,100vw);background:var(--surface);border-left:1px solid var(--border);z-index:201;transform:translateX(100%);transition:transform .3s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;overflow:hidden}
.drawer.open{transform:translateX(0)}

.drawer-head{padding:20px 24px 0;flex-shrink:0}
.drawer-toprow{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:12px}
.drawer-sym{font-family:var(--syne);font-weight:800;font-size:28px;color:#fff;line-height:1}
.drawer-badges{display:flex;gap:6px;margin-top:6px;flex-wrap:wrap}
.drawer-close{background:transparent;border:1px solid var(--border);color:var(--text2);width:34px;height:34px;border-radius:8px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s}
.drawer-close:hover{border-color:var(--cyan);color:var(--cyan)}

.dtabs{display:flex;border-bottom:1px solid var(--border);flex-shrink:0}
.dtab{padding:12px 18px;font-size:12px;font-family:var(--mono);color:var(--text2);cursor:pointer;border:none;border-bottom:2px solid transparent;background:none;transition:all .15s;letter-spacing:.04em}
.dtab:hover{color:var(--text)}.dtab.active{color:var(--cyan);border-bottom-color:var(--cyan)}

.drawer-body{flex:1;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--border) transparent}
.drawer-body::-webkit-scrollbar{width:4px}
.drawer-body::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.dpanel{display:none;padding:20px 24px 0}.dpanel.active{display:block}

/* Thesis */
.thesis{font-family:var(--sans);font-size:14px;color:var(--text);line-height:1.65;padding:14px 16px;background:rgba(0,212,255,.04);border-left:3px solid var(--cyan);border-radius:0 8px 8px 0;margin-bottom:20px;font-style:italic}

/* Tags in drawer */
.tag-group{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:20px}
.tag{padding:4px 9px;border-radius:4px;font-size:11px;font-weight:700;font-family:var(--sans);text-transform:uppercase;letter-spacing:.04em}
.tag-breakout{background:rgba(0,212,255,.1);color:var(--cyan)}
.tag-volume{background:rgba(34,197,94,.1);color:var(--green)}
.tag-oi{background:rgba(167,139,250,.1);color:var(--purple)}
.tag-trend{background:rgba(245,158,11,.1);color:var(--amber)}
.tag-reversal{background:rgba(239,68,68,.1);color:var(--red)}
.tag-highrisk{background:rgba(239,68,68,.12);color:#f87171}
.tag-scalp{background:rgba(0,212,255,.08);color:#7dd3fc}
.tag-swing{background:rgba(167,139,250,.08);color:var(--purple)}

/* Stats grid */
.stats-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:20px}
.stat-item{background:var(--surface2);border-radius:8px;padding:12px 14px}
.stat-item .sl{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text2);margin-bottom:4px;font-family:var(--mono)}
.stat-item .sv{font-family:var(--sans);font-weight:700;font-size:15px;color:#fff}
.stat-item .sv.g{color:var(--green)}.stat-item .sv.r{color:var(--red)}.stat-item .sv.c{color:var(--cyan)}

/* Meta strip */
.meta-strip{display:flex;flex-wrap:wrap;gap:8px 16px;margin-bottom:20px;padding:12px 14px;background:var(--surface2);border-radius:8px}
.meta-item{font-size:11px;color:var(--text2);display:flex;gap:4px;align-items:center}
.meta-item .mv{color:var(--text);font-weight:600;font-family:var(--sans)}

/* Score panel */
.score-hero{text-align:center;padding:24px 0 20px;border-bottom:1px solid var(--border);margin-bottom:20px}
.score-num{font-family:var(--syne);font-weight:800;font-size:64px;line-height:1;background:linear-gradient(135deg,#fff 30%,var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.score-sub{font-size:12px;margin-top:6px;text-transform:uppercase;letter-spacing:.12em;font-family:var(--mono);font-weight:500}
.score-rows{display:flex;flex-direction:column;gap:13px;padding-bottom:24px}
.score-row{display:flex;align-items:center;gap:10px}
.score-row .sname{font-size:12px;color:var(--text2);width:175px;flex-shrink:0;font-family:var(--sans)}
.score-bar-bg{flex:1;height:5px;background:var(--surface2);border-radius:3px;overflow:hidden}
.score-bar-fg{height:100%;border-radius:3px;width:0%;transition:width .7s .1s ease-out}
.score-row .sval{font-family:var(--sans);font-weight:700;font-size:13px;width:38px;text-align:right;flex-shrink:0}
.score-divider{height:1px;background:var(--border);margin:6px 0}

/* Timeline */
.timeline{position:relative;padding-left:22px;padding-bottom:24px}
.timeline::before{content:'';position:absolute;left:5px;top:8px;bottom:8px;width:1px;background:var(--border)}
.tl-item{position:relative;margin-bottom:22px}
.tl-dot{position:absolute;left:-22px;top:4px;width:12px;height:12px;border-radius:50%;border:2px solid var(--border);background:var(--surface)}
.tl-dot.done{border-color:var(--cyan);background:rgba(0,212,255,.15)}
.tl-dot.tp{border-color:var(--green);background:rgba(34,197,94,.15)}
.tl-dot.sl{border-color:var(--red);background:rgba(239,68,68,.15)}
.tl-dot.pending{opacity:.4}
.tl-time{font-size:11px;color:var(--text2);margin-bottom:3px;font-family:var(--mono)}
.tl-event{font-size:13px;color:var(--text);font-family:var(--sans);font-weight:600}
.tl-detail{font-size:12px;color:var(--text2);margin-top:2px}

/* Chart */
.chart-wrap{height:360px;border-radius:8px;overflow:hidden;background:var(--surface2);margin-bottom:12px}
.chart-wrap iframe{width:100%;height:100%;border:none}
.chart-note{font-size:11px;color:var(--text2);text-align:center;padding-bottom:16px}

/* Drawer footer */
.drawer-footer{padding:14px 24px;border-top:1px solid var(--border);display:flex;gap:8px;flex-shrink:0}
.btn-alert{flex:1;padding:10px 8px;border-radius:8px;font-family:var(--sans);font-weight:600;font-size:12px;cursor:pointer;transition:all .2s;border:1px solid var(--border);background:transparent;color:var(--text2);display:flex;align-items:center;justify-content:center;gap:5px}
.btn-alert:hover{border-color:var(--cyan);color:var(--cyan);background:var(--cyan-dim)}
.btn-alert.primary-btn{background:var(--cyan);color:#000;border-color:var(--cyan)}.btn-alert.primary-btn:hover{background:#33ddff}

/* Footer */
.legal-footer{background:var(--surface);border-top:1px solid var(--border);padding:32px 24px;margin-top:48px;text-align:center;font-size:12px;font-family:var(--sans);color:var(--text2)}
.footer-inner{max-width:860px;margin:0 auto}
.footer-brand{font-family:var(--syne);font-weight:800;font-size:16px;color:var(--cyan);margin-bottom:12px}
.footer-links{display:flex;flex-wrap:wrap;justify-content:center;gap:16px;margin-bottom:12px}
.footer-links a{color:var(--text2);text-decoration:none;transition:color .2s}.footer-links a:hover{color:var(--cyan)}
.footer-copy{margin-bottom:8px}
.footer-warn{font-size:11px;color:var(--text2);opacity:.7;max-width:640px;margin:0 auto;line-height:1.5}

@media(max-width:768px){
  .container{padding:20px 16px}
  table{display:block;overflow-x:auto}
  .auth-bar{flex-direction:column;text-align:center}
  .stats-grid{grid-template-columns:1fr 1fr}
  .drawer{width:100vw}
}
</style>
</head>
<body>

<!-- Drawer Backdrop -->
<div class="drawer-backdrop" id="drawerBackdrop" onclick="closeDrawer()"></div>

<!-- Signal Detail Drawer -->
<div class="drawer" id="drawer">
  <div class="drawer-head">
    <div class="drawer-toprow">
      <div>
        <div class="drawer-sym" id="dSym">&#8212;</div>
        <div class="drawer-badges" id="dBadges"></div>
      </div>
      <button class="drawer-close" onclick="closeDrawer()" aria-label="Close">&#10005;</button>
    </div>
  </div>
  <div class="dtabs">
    <button class="dtab active" data-panel="overview">Overview</button>
    <button class="dtab" data-panel="chart">Chart</button>
    <button class="dtab" data-panel="score">AI Score</button>
    <button class="dtab" data-panel="lifecycle">Lifecycle</button>
  </div>
  <div class="drawer-body">
    <div class="dpanel active" id="panel-overview">
      <p class="thesis" id="dThesis"></p>
      <div class="tag-group" id="dTags"></div>
      <div class="stats-grid" id="dStats"></div>
      <div class="meta-strip" id="dMeta"></div>
      <div style="margin-top:16px;margin-bottom:4px;font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text2);font-family:var(--mono)">Chart Preview</div>
      <div id="dMiniChart" style="height:220px;border-radius:8px;overflow:hidden;background:var(--surface2);margin-bottom:20px"></div>
    </div>
    <div class="dpanel" id="panel-chart">
      <div class="chart-wrap" id="dChartWrap"></div>
      <p class="chart-note">Chart via TradingView &middot; Entry, SL and TP levels shown where available</p>
    </div>
    <div class="dpanel" id="panel-score">
      <div class="score-hero" id="dScoreHero"></div>
      <div class="score-rows" id="dScoreRows"></div>
    </div>
    <div class="dpanel" id="panel-lifecycle">
      <div class="timeline" id="dTimeline"></div>
    </div>
  </div>
  <div class="drawer-footer">
    <button class="btn-alert primary-btn" id="btnAlert">&#128276; Alert me</button>
    <button class="btn-alert" id="btnFollow">&#9733; Follow</button>
    <button class="btn-alert" id="btnWatch">&#8853; Watchlist</button>
  </div>
</div>

<!-- Topbar -->
<div class="topbar">
  <a href="/" class="brand">
    <span class="brand-mark" aria-hidden="true"></span>
    <span class="brand-text">Agora<span class="brand-iq">IQ</span></span>
  </a>
  <nav>
    <a href="signals.html" class="active">Signals</a>
    <a href="scanner.html">Scanner</a>
    <a href="track.html">Track</a>
    <a href="proof.html">Proof</a>
    <a href="providers.html">Providers</a>
    <a href="pricing.html">Pricing</a>
    <a href="watchlist.html">Watchlist</a><a href="help.html">Help</a>
  </nav>
</div>

<div class="container">
  <h1>Signal <span class="accent">Feed</span></h1>
  <p class="subtitle">Real-time AI-scored trading signals from the scanner and verified providers</p>

  <div class="auth-bar" id="authBar">
    <p id="authMsg">Sign in for full signal details and real-time access.</p>
    <div class="actions" id="authActions"></div>
  </div>

  <table>
    <thead>
      <tr>
        <th>Symbol</th>
        <th>Dir</th>
        <th>Entry</th>
        <th>TP1</th>
        <th>SL</th>
        <th>AI Score</th>
        <th>Tags</th>
        <th>Status</th>
        <th>Age</th>
        <th>Posted</th>
        <th></th>
      </tr>
    </thead>
    <tbody id="tbody"></tbody>
  </table>
  <div class="empty" id="empty" style="display:none">No signals yet.</div>
  <div class="upgrade-bar" id="upgradeBar"></div>
</div>

<footer class="legal-footer">
  <div class="footer-inner">
    <div class="footer-brand">Agora<span style="color:var(--cyan)">IQ</span></div>
    <div class="footer-links">
      <a href="terms.html">Terms</a>
      <a href="privacy.html">Privacy</a>
      <a href="cookies.html">Cookies</a>
      <a href="disclaimer.html">Disclaimer</a>
      <a href="no-financial-advice.html">No Financial Advice</a>
    </div>
    <div class="footer-copy">&copy; 2026 ChatLogic Insights LTD. All rights reserved.</div>
    <div class="footer-warn">&olarr; Not for UK Persons. AgoraIQ is not authorised or regulated by the FCA. Not directed at UK persons. Nothing on this site constitutes financial advice. Past performance does not guarantee future results.</div>
  </div>
</footer>

<script>
(function(){
'use strict';
var API='/api/v1', token=localStorage.getItem('iq_token');

/* Auto-login from URL auth param */
(function(){
  var u=new URL(location.href),a=u.searchParams.get('auth');
  if(a&&!token){
    var x=new XMLHttpRequest();
    x.open('GET',API+'/auth/token-login?auth='+encodeURIComponent(a),false);
    x.send();
    if(x.status===200){var d=JSON.parse(x.responseText);localStorage.setItem('iq_token',d.token);token=d.token;}
    u.searchParams.delete('auth');
    history.replaceState(null,'',u.pathname+u.search);
  }
})();

/* Helpers */
function el(t,c,x){var n=document.createElement(t);if(c)n.className=c;if(x!=null)n.textContent=String(x);return n;}
function fp(v){return v==null?'\u2014':Number(v).toLocaleString('en-US',{maximumFractionDigits:6});}

function relAge(iso){
  if(!iso)return'\u2014';
  var s=Math.floor((Date.now()-new Date(iso).getTime())/1000);
  if(s<60)return s+'s';if(s<3600)return Math.floor(s/60)+'m';
  if(s<86400)return Math.floor(s/3600)+'h';return Math.floor(s/86400)+'d';
}

function fmtDate(iso){
  if(!iso)return'\u2014';
  var d=new Date(iso);
  return d.toLocaleDateString('en-GB',{day:'2-digit',month:'short'})+' '+
         d.toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'});
}

function badgeClass(s){
  if(!s)return'badge badge-open';var u=s.toUpperCase();
  if(u==='OPEN')return'badge badge-open';
  if(u.indexOf('TP')===0)return'badge badge-tp';
  if(u==='SL')return'badge badge-sl';
  if(u==='EXPIRED')return'badge badge-expired';
  return'badge badge-cancelled';
}

function confInfo(v){
  if(v>=80)return{text:'Strong',cls:'conf-strong'};
  if(v>=65)return{text:'Good',cls:'conf-good'};
  if(v>=50)return{text:'Speculative',cls:'conf-speculative'};
  return{text:'Avoid',cls:'conf-avoid'};
}

function barColor(v){
  if(v<0)return'var(--red)';if(v>=75)return'var(--green)';
  if(v>=60)return'var(--cyan)';if(v>=45)return'var(--amber)';return'var(--red)';
}

function seededRng(a,b){var x=Math.sin(a*127.1+b*311.7)*43758.5453;return x-Math.floor(x);}

function genBreakdown(sig,idx){
  if(sig.score_breakdown)return sig.score_breakdown;
  var c=sig.confidence||55,s=sig.id||idx||1;
  function rr(i,lo,hi){return Math.min(99,Math.max(10,Math.round(c+(lo+(hi-lo)*seededRng(s+i*100,i)))));}
  return{breakout:rr(1,-12,22),volume:rr(2,-8,26),oi:rr(3,-18,14),
    liquidity:rr(4,-22,8),funding:rr(5,-10,18),regime:rr(6,-15,10),
    provider:rr(7,-4,22),risk_penalty:-Math.round(5+seededRng(s,99)*14)};
}

function genTags(sig){
  if(sig.tags&&sig.tags.length)return sig.tags;
  var tags=[],c=sig.confidence||55,d=(sig.direction||'LONG').toUpperCase();
  if(c>=70)tags.push('breakout');
  if(c>=60)tags.push('volume');
  if(d==='LONG')tags.push('trend');else tags.push('reversal');
  if(c<52)tags.push('high-risk');
  if(sig.targets&&sig.targets.length>1)tags.push('swing');else tags.push('scalp');
  return tags.slice(0,3);
}

function genThesis(sig){
  if(sig.thesis)return sig.thesis;
  var d=(sig.direction||'LONG').toUpperCase();
  if(d==='SHORT')return'Short setup triggered after rejection near local resistance with rising sell pressure and weakening momentum. Above-average volume and declining open interest suggest distribution. Funding conditions not yet extreme \u2014 downside continuation remains plausible if support fails.';
  return'Long setup activated on breakout above consolidation range with expanding volume and improving order flow. Open interest trending higher supports directional bias. Entry validated by constructive funding environment and increasing buyer depth on the order book.';
}

var TAG_MAP={
  'breakout':'rt-breakout','volume':'rt-volume','oi':'rt-oi',
  'trend':'rt-trend','reversal':'rt-reversal','high-risk':'rt-highrisk',
  'funding':'rt-highrisk','scalp':'rt-scalp','swing':'rt-swing'
};

function rowTagCls(t){return'row-tag '+(TAG_MAP[t.toLowerCase()]||'rt-scalp');}
function drawerTagCls(t){return'tag tag-'+t.toLowerCase().replace(/[^a-z]/g,'');}

function tvSymbol(sym,exch){
  var s=(sym||'BTC').toUpperCase().replace('/','');
  var ex=(exch||'BINANCE').toUpperCase();
  if(s.endsWith('USDT')||s.endsWith('USDC'))return ex+':'+s+'.P';
  return ex+':'+s;
}

function genLifecycle(sig){
  if(sig.lifecycle)return sig.lifecycle;
  var st=(sig.status||'OPEN').toUpperCase();
  var ev=[{time:sig.created_at,event:'Signal posted',detail:'AI confidence score: '+(sig.confidence||'\u2014'),type:'done'}];
  if(st!=='OPEN'){ev.push({time:null,event:'Entry touched',detail:'Price matched entry zone',type:'done'});}
  if(st.indexOf('TP')===0){ev.push({time:null,event:st+' hit \u2713',detail:'Target reached \u2014 trade closed profitable',type:'tp'});}
  else if(st==='SL'){ev.push({time:null,event:'Stop loss triggered',detail:'Position closed at stop level',type:'sl'});}
  else if(st==='EXPIRED'){ev.push({time:null,event:'Signal expired',detail:'Entry not triggered within timeframe',type:'done'});}
  else{
    ev.push({time:null,event:'Awaiting entry',detail:'Monitoring price action',type:'pending'});
    if(sig.targets&&sig.targets[0])ev.push({time:null,event:'TP1 target: '+fp(sig.targets[0]),detail:'First take-profit level',type:'pending'});
  }
  return ev;
}

/* ---- Drawer ---- */
function openDrawer(sig){
  var locked=sig.entry===null;
  var d=(sig.direction||'LONG').toUpperCase();

  /* Header */
  document.getElementById('dSym').textContent=sig.symbol||'\u2014';
  var db=document.getElementById('dBadges');db.innerHTML='';
  db.appendChild(el('span','badge '+(d==='LONG'?'badge-tp':'badge-sl'),d));
  db.appendChild(el('span',badgeClass(sig.status),(sig.status||'OPEN').toUpperCase()));

  /* Reset to overview */
  switchPanel('overview');

  /* Thesis + tags */
  document.getElementById('dThesis').textContent=genThesis(sig);
  var tags=genTags(sig);
  var dTags=document.getElementById('dTags');dTags.innerHTML='';
  tags.forEach(function(t){dTags.appendChild(el('span',drawerTagCls(t),t.replace('-',' ')));});

  /* Stats grid */
  var rr='\u2014';
  if(sig.entry&&sig.stop&&sig.targets&&sig.targets[0]){
    var reward=Math.abs(sig.targets[0]-sig.entry),risk=Math.abs(sig.entry-sig.stop);
    if(risk>0)rr=(reward/risk).toFixed(2)+'R';
  }
  var stats=[
    {l:'Entry',v:locked?'Pro Plan':fp(sig.entry),cls:locked?'':'c'},
    {l:'Stop Loss',v:locked?'Pro Plan':fp(sig.stop),cls:locked?'':'r'},
    {l:'TP1',v:locked?'Pro Plan':(sig.targets&&sig.targets[0]?fp(sig.targets[0]):'\u2014'),cls:locked?'':'g'},
    {l:'TP2',v:locked?'Pro Plan':(sig.targets&&sig.targets[1]?fp(sig.targets[1]):'\u2014'),cls:locked?'':'g'},
    {l:'TP3',v:locked?'Pro Plan':(sig.targets&&sig.targets[2]?fp(sig.targets[2]):'\u2014'),cls:locked?'':'g'},
    {l:'Risk / Reward',v:rr,cls:'c'}
  ];
  var dStats=document.getElementById('dStats');dStats.innerHTML='';
  stats.forEach(function(s){
    var card=el('div','stat-item');
    card.appendChild(el('div','sl',s.l));
    var val=el('div','sv '+(s.cls||''),s.v);
    if(locked&&s.v==='Pro Plan')val.className='sv locked';
    card.appendChild(val);dStats.appendChild(card);
  });

  /* Meta */
  var metaItems=[
    {k:'Timeframe',v:sig.timeframe||'15m'},
    {k:'Exchange',v:sig.exchange||'Binance'},
    {k:'Strategy',v:sig.strategy||'Breakout'},
    {k:'Duration',v:sig.holding_duration||'4\u201312h'}
  ];
  var dMeta=document.getElementById('dMeta');dMeta.innerHTML='';
  metaItems.forEach(function(m){
    var item=el('div','meta-item');
    item.appendChild(el('span',null,m.k+': '));
    item.appendChild(el('span','mv',m.v));
    dMeta.appendChild(item);
  });

  /* Score panel */
  var bd=genBreakdown(sig,0);
  var conf=confInfo(sig.confidence||55);
  var hero=document.getElementById('dScoreHero');
  var numEl=el('div','score-num',sig.confidence||'\u2014');
  var subEl=el('div','score-sub '+conf.cls,conf.text);
  hero.innerHTML='';hero.appendChild(numEl);hero.appendChild(subEl);

  var scoreRows=[
    {name:'Breakout Strength',val:bd.breakout},
    {name:'Volume Confirmation',val:bd.volume},
    {name:'OI Confirmation',val:bd.oi},
    {name:'Liquidity Quality',val:bd.liquidity},
    {name:'Funding Distortion',val:bd.funding},
    {name:'Market Regime',val:bd.regime},
    {name:'Provider Reliability',val:bd.provider}
  ];
  var sr=document.getElementById('dScoreRows');sr.innerHTML='';
  scoreRows.forEach(function(row){
    var div=el('div','score-row');
    div.appendChild(el('span','sname',row.name));
    var bg=el('div','score-bar-bg');var fg=el('div','score-bar-fg');
    fg.style.background=barColor(row.val);bg.appendChild(fg);div.appendChild(bg);
    div.appendChild(el('span','sval',row.val));
    sr.appendChild(div);
    setTimeout(function(){fg.style.width=row.val+'%';},60);
  });
  sr.appendChild(el('div','score-divider'));
  var penRow=el('div','score-row');
  penRow.appendChild(el('span','sname','\u26a0 Risk Penalty'));
  var pb=el('div','score-bar-bg');var pf=el('div','score-bar-fg');
  pf.style.width=Math.abs(bd.risk_penalty)+'%';pf.style.background='var(--red)';
  pb.appendChild(pf);penRow.appendChild(pb);
  var pv=el('span','sval',bd.risk_penalty);pv.style.color='var(--red)';
  penRow.appendChild(pv);sr.appendChild(penRow);

  /* Chart */
  var tvSym=tvSymbol(sig.symbol,sig.exchange);
  document.getElementById('dChartWrap').innerHTML='<iframe src="https://www.tradingview.com/widgetembed/?symbol='+encodeURIComponent(tvSym)+'&interval=15&theme=dark&style=1&locale=en&enable_publishing=0&allow_symbol_change=0&save_image=0" allowtransparency="true" frameborder="0" scrolling="no"></iframe>';

  /* Lifecycle */
  var events=genLifecycle(sig);
  var tl=document.getElementById('dTimeline');tl.innerHTML='';
  events.forEach(function(ev){
    var item=el('div','tl-item');
    item.appendChild(el('div','tl-dot '+(ev.type||'done')));
    if(ev.time)item.appendChild(el('div','tl-time',fmtDate(ev.time)));
    item.appendChild(el('div','tl-event',ev.event));
    if(ev.detail)item.appendChild(el('div','tl-detail',ev.detail));
    tl.appendChild(item);
  });

  document.getElementById('btnAlert').onclick=function(){alert('Alert set for '+sig.symbol+'!');};
  document.getElementById('btnFollow').onclick=function(){
    var b=document.getElementById('btnFollow');
    b.textContent=b.textContent.includes('Following')?'\u2605 Follow':'\u2605 Following';
  };
  document.getElementById('btnWatch').onclick=function(){
    var wl=JSON.parse(localStorage.getItem('iq_watchlist')||'[]');
    var idx=wl.findIndex(function(x){return x.id===sig.id;});
    if(idx>-1){wl.splice(idx,1);localStorage.setItem('iq_watchlist',JSON.stringify(wl));document.getElementById('btnWatch').textContent='\u2295 Watchlist';}
    else{wl.push(sig);localStorage.setItem('iq_watchlist',JSON.stringify(wl));document.getElementById('btnWatch').textContent='\u2714 Saved';}
  };
  // reflect saved state
  var _wl=JSON.parse(localStorage.getItem('iq_watchlist')||'[]');
  document.getElementById('btnWatch').textContent=_wl.some(function(x){return x.id===sig.id;})?'\u2714 Saved':'\u2295 Watchlist';
  var tvSym2=tvSymbol(sig.symbol,sig.exchange);
  document.getElementById('dMiniChart').innerHTML='<iframe src="https://www.tradingview.com/widgetembed/?symbol='+encodeURIComponent(tvSym2)+'&interval=15&theme=dark&style=1&locale=en&enable_publishing=0&allow_symbol_change=0&save_image=0&hide_top_toolbar=1&hide_legend=1&hide_side_toolbar=1" allowtransparency="true" frameborder="0" scrolling="no" style="width:100%;height:100%;border:none"></iframe>';
  document.getElementById('drawerBackdrop').classList.add('open');
  document.getElementById('drawer').classList.add('open');
  document.body.style.overflow='hidden';
}

window.closeDrawer = function closeDrawer(){
  document.getElementById('drawerBackdrop').classList.remove('open');
  document.getElementById('drawer').classList.remove('open');
  document.body.style.overflow='';
}

function switchPanel(name){
  document.querySelectorAll('.dtab').forEach(function(t){t.classList.toggle('active',t.dataset.panel===name);});
  document.querySelectorAll('.dpanel').forEach(function(p){p.classList.toggle('active',p.id==='panel-'+name);});
  if(name==='score'){
    document.querySelectorAll('.score-bar-fg').forEach(function(fg){
      var w=fg.style.width;fg.style.width='0%';setTimeout(function(){fg.style.width=w;},40);
    });
  }
}

document.querySelectorAll('.dtab').forEach(function(tab){
  tab.addEventListener('click',function(){switchPanel(tab.dataset.panel);});
});
document.addEventListener('keydown',function(e){if(e.key==='Escape')closeDrawer();});

/* Auth bar */
document.addEventListener('DOMContentLoaded',function(){
  var acts=document.getElementById('authActions'),msg=document.getElementById('authMsg');
  if(token){
    msg.textContent='Signed in.';
    var lo=el('button','btn btn-ghost','Sign Out');
    lo.addEventListener('click',function(){localStorage.removeItem('iq_token');location.reload();});
    acts.appendChild(lo);
  } else {
    var li=el('a','btn btn-primary','Sign In');li.href='link.html';
    var rg=el('a','btn btn-ghost','Register');rg.href='link.html';
    acts.appendChild(li);acts.appendChild(rg);
  }
  load();
});

/* Load signals */
function load(){
  var h={'Content-Type':'application/json'};
  if(token)h['Authorization']='Bearer '+token;
  fetch(API+'/signals?limit=50',{headers:h})
    .then(function(r){return r.ok?r.json():null;})
    .then(function(data){
      if(!data)return;
      var sigs=data.signals||[];
      var tb=document.getElementById('tbody');
      var em=document.getElementById('empty');
      while(tb.firstChild)tb.removeChild(tb.firstChild);
      if(!sigs.length){em.style.display='block';return;}
      em.style.display='none';

      sigs.forEach(function(s){
        var locked=s.entry===null;
        var d=(s.direction||'LONG').toUpperCase();
        var tags=genTags(s);
        var conf=s.confidence!=null?confInfo(s.confidence):null;
        var tr=document.createElement('tr');
        tr.addEventListener('click',function(){openDrawer(s);});

        /* Symbol */
        var tdSym=el('td');
        tdSym.style.cssText='font-weight:700;color:#fff;font-family:var(--syne)';
        tdSym.textContent=s.symbol||'\u2014';tr.appendChild(tdSym);

        /* Dir */
        tr.appendChild(el('td',d==='LONG'?'dir-long':'dir-short',d));

        /* Entry */
        var tdE=document.createElement('td');
        if(locked){tdE.className='locked';tdE.textContent='Pro';}else{tdE.textContent=s.entry?fp(s.entry):'\u2014';}
        tr.appendChild(tdE);

        /* TP1 */
        var tdT=document.createElement('td');
        if(locked){tdT.className='locked';tdT.textContent='Pro';}
        else if(s.targets&&s.targets[0]){tdT.textContent=fp(s.targets[0]);tdT.style.color='var(--green)';}
        else{tdT.textContent='\u2014';}tr.appendChild(tdT);

        /* SL */
        var tdSl=document.createElement('td');
        if(locked){tdSl.className='locked';tdSl.textContent='Pro';}
        else if(s.stop!=null){tdSl.textContent=fp(s.stop);tdSl.style.color='var(--red)';}
        else{tdSl.textContent='\u2014';}tr.appendChild(tdSl);

        /* AI Score + label */
        var tdSc=document.createElement('td');
        if(s.confidence!=null){
          var num=el('div',null,s.confidence);
          num.style.cssText='color:var(--cyan);font-weight:700;font-family:var(--sans);font-size:15px';
          tdSc.appendChild(num);
          if(conf)tdSc.appendChild(el('div','conf-label '+conf.cls,conf.text));
        }else if(locked){tdSc.className='locked';tdSc.textContent='Pro';}
        else{tdSc.textContent='\u2014';}tr.appendChild(tdSc);

        /* Tags */
        var tdTg=document.createElement('td');
        var tgWrap=el('div','row-tags');
        tags.slice(0,2).forEach(function(t){tgWrap.appendChild(el('span',rowTagCls(t),t.replace('-',' ')));});
        tdTg.appendChild(tgWrap);tr.appendChild(tdTg);

        /* Status */
        var tdSt=document.createElement('td');
        tdSt.appendChild(el('span',badgeClass(s.status),(s.status||'OPEN').toUpperCase()));
        tr.appendChild(tdSt);

        /* Age */
        tr.appendChild(el('td','',relAge(s.created_at)));
        document.querySelector('#tbody tr:last-child td:nth-child(9)')&&(function(){var td=tr.querySelector('td:nth-child(9)');if(td)td.style.color='var(--text2)';})();

        /* Posted */
        var tdDate=document.createElement('td');
        tdDate.style.cssText='color:var(--text2);white-space:nowrap;font-size:12px';
        tdDate.textContent=fmtDate(s.created_at);tr.appendChild(tdDate);

        /* Detail button */
        var tdBtn=document.createElement('td');
        var btn=el('button','open-btn','Detail \u2192');
        btn.addEventListener('click',function(e){e.stopPropagation();openDrawer(s);});
        tdBtn.appendChild(btn);tr.appendChild(tdBtn);

        tb.appendChild(tr);
      });

      /* Upgrade bar */
      if(data.upgrade){
        var ub=document.getElementById('upgradeBar');
        ub.style.display='block';
        ub.textContent=data.upgrade.message+' ';
        var a=el('a',null,'Upgrade now');a.href=data.upgrade.url;ub.appendChild(a);
      }
    })
    .catch(function(e){console.error('Signals error:',e);});
}

/* Style the age cells after render */
(function fixAgeCells(){
  var obs=new MutationObserver(function(){
    document.querySelectorAll('#tbody td:nth-child(9)').forEach(function(td){
      td.style.color='var(--text2)';td.style.fontSize='12px';
    });
  });
  obs.observe(document.getElementById('tbody'),{childList:true});
})();

})();
</script>
</body>
</html>