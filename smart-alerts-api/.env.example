# ══════════════════════════════════════════════════════════════════════
#  agoraiq-smart-alerts — ISOLATED SIDECAR environment
#  Own DB, own Redis keyspace, own auth secrets. Zero shared state.
# ══════════════════════════════════════════════════════════════════════

# ── Service ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4310
LOG_LEVEL=info

# ── Database (ISOLATED — must NOT point at agoraiq_signals) ────────
DATABASE_URL=postgresql://agoraiq_smart_alerts:CHANGE_ME@127.0.0.1:5432/agoraiq_smart_alerts

# ── Redis (own keyspace prefix) ────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=sa:

# ── Auth ───────────────────────────────────────────────────────────
# JWT secret MUST match agoraiq-signals-api so tokens issued by the
# main app are accepted locally. Verification is local — no RPC.
JWT_SECRET=CHANGE_ME_TO_MATCH_MAIN_APP

# HMAC secret for inbound signal webhook (main app → this service)
SIGNAL_WEBHOOK_HMAC_SECRET=CHANGE_ME_LONG_RANDOM
SIGNAL_WEBHOOK_MAX_SKEW_SEC=300

# Internal API key the main app accepts for plan lookups
MAIN_API_BASE_URL=http://127.0.0.1:4300
MAIN_API_INTERNAL_KEY=CHANGE_ME_LONG_RANDOM
PLAN_CACHE_TTL_SEC=300

# ── Telegram delivery ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:CHANGE_ME
TELEGRAM_SEND_TIMEOUT_MS=5000

# ── LLM fallback (optional) ────────────────────────────────────────
LLM_ENABLED=false
HF_API_KEY=
HF_BASE_URL=https://api-inference.huggingface.co
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── Queue ──────────────────────────────────────────────────────────
QUEUE_CONCURRENCY=5
QUEUE_RATE_PER_SEC=25
QUEUE_MAX_RETRIES=3

# ── Rate limiting ──────────────────────────────────────────────────
RATE_LIMIT_PER_MIN=60
