# ═══════════════════════════════════════════════════════════════════
#  agoraiq-signals-api — example environment
#  Copy to .env and fill in real values. DO NOT commit .env.
# ═══════════════════════════════════════════════════════════════════

# Database
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/agoraiq_signals

# Auth
JWT_SECRET=change-me-to-a-64-char-random-string
TOKEN_EXPIRY=7d

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Telegram bot
BOT_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ELITE=
STRIPE_PRICE_ELITE_YEARLY=

# URLs
APP_URL=https://signals.agoraiq.net
PORT=4300
NODE_ENV=production

# HuggingFace AI
HF_API_KEY=
HF_BASE_URL=https://api-inference.huggingface.co
HF_PROVIDER=hf-inference
HF_SIGNAL_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_REGIME_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_NARRATIVE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Perplexity (providers-api)
PPLX_API_KEY=

# Email (Brevo)
BREVO_API_KEY=
