/**
 * AI scoring engine — AgoraIQ Signals
 *
 * Primary:  Gemini 2.5 Flash-Lite (free tier)
 * Fallback: Perplexity sonar
 * Safety:   Local heuristic-v3
 *
 * Env vars:
 *   GEMINI_API_KEY     — Google AI Studio key (primary)
 *   PPLX_API_KEY       — Perplexity API key (fallback)
 *   PPLX_MODEL         — Perplexity model name (default: sonar)
 *   PPLX_TIMEOUT_MS    — Perplexity request timeout (default: 20000)
 *   GEMINI_TIMEOUT_MS  — Gemini request timeout (default: 15000)
 */

// ── Gemini config ─────────────────────────────────────────────────
const GEMINI_API_KEY = process.env.GEMINI_API_KEY || null;
const GEMINI_MODEL = "gemini-2.5-flash-lite";
const GEMINI_URL = `https://generativelanguage.googleapis.com/v1beta/models/${GEMINI_MODEL}:generateContent`;
const GEMINI_TIMEOUT = parseInt(process.env.GEMINI_TIMEOUT_MS) || 15000;

// ── OpenRouter / Llama 4 Scout config (second fallback) ──────
const OPENROUTER_API_KEY = process.env.OPENROUTER_API_KEY || null;
const LLAMA_MODEL = "meta-llama/llama-3.3-70b-instruct:free";
const OPENROUTER_URL = "https://openrouter.ai/api/v1/chat/completions";
const LLAMA_TIMEOUT = parseInt(process.env.LLAMA_TIMEOUT_MS) || 20000;

// ── Perplexity config (fallback) ──────────────────────────────────
const PPLX_API_KEY = process.env.PPLX_API_KEY || null;
const PPLX_MODEL = process.env.PPLX_MODEL || "sonar";
const PPLX_BASE_URL = "https://api.perplexity.ai";
const PPLX_TIMEOUT = parseInt(process.env.PPLX_TIMEOUT_MS) || 20000;
const PPLX_RETRIES = 2;

const REGIMES = ["breakout", "trend", "chop", "mean_reversion"];
const RISK_FLAGS = ["crowded", "thin_liquidity", "extreme_funding", "no_stop_loss", "extreme_leverage", "low_rr", "high_leverage"];
const SIGNAL_TAGS = ["breakout", "volume", "trend", "reversal", "scalp", "swing", "high-risk", "oi"];

// ── Chat completions request ─────────────────────────────────────

async function pplxChat(systemPrompt, userPrompt, maxTokens = 800) {
  if (!PPLX_API_KEY) {
    console.warn("[ai] PPLX_API_KEY not set — returning fallback");
    return null;
  }

  const body = JSON.stringify({
    model: PPLX_MODEL,
    messages: [
      { role: "system", content: systemPrompt },
      { role: "user", content: userPrompt },
    ],
    max_tokens: maxTokens,
    temperature: 0.2,
  });

  for (let attempt = 0; attempt <= PPLX_RETRIES; attempt++) {
    try {
      const res = await fetch(`${PPLX_BASE_URL}/chat/completions`, {
        method: "POST",
        headers: {
          Authorization: `Bearer ${PPLX_API_KEY}`,
          "Content-Type": "application/json",
        },
        body,
        signal: AbortSignal.timeout(PPLX_TIMEOUT),
      });

      if (res.status === 429 && attempt < PPLX_RETRIES) {
        const retryAfter = parseInt(res.headers.get("retry-after")) || 3;
        console.warn(`[ai] PPLX 429 (rate limit), retry after ${retryAfter}s`);
        await sleep(retryAfter * 1000);
        continue;
      }

      if (res.status >= 500 && attempt < PPLX_RETRIES) {
        console.warn(`[ai] PPLX ${res.status}, retry ${attempt + 1}/${PPLX_RETRIES}`);
        await sleep(1000 * (attempt + 1));
        continue;
      }

      if (!res.ok) {
        const text = await res.text();
        console.error(`[ai] PPLX ${res.status}: ${text.slice(0, 300)}`);
        return null;
      }

      const data = await res.json();
      const content = data?.choices?.[0]?.message?.content;
      if (!content) {
        const preview = JSON.stringify(data).slice(0, 200);
        console.warn(`[ai] PPLX response missing content: ${preview}`);
        return null;
      }
      return content;
    } catch (err) {
      if (err.name === "AbortError" || err.name === "TimeoutError") {
        console.warn(`[ai] PPLX timeout (${PPLX_TIMEOUT}ms), attempt ${attempt + 1}`);
        if (attempt < PPLX_RETRIES) { await sleep(1000); continue; }
      }
      console.error(`[ai] PPLX request failed: ${err.message}`);
      return null;
    }
  }
  return null;
}


// ── Gemini Flash-Lite ─────────────────────────────────────────────

async function geminiChat(systemPrompt, userPrompt, maxTokens = 800) {
  if (!GEMINI_API_KEY) {
    console.warn("[ai] GEMINI_API_KEY not set — skipping Gemini");
    return null;
  }
  const combinedPrompt = `${systemPrompt}

${userPrompt}`;
  try {
    const res = await fetch(`${GEMINI_URL}?key=${GEMINI_API_KEY}`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        contents: [{ parts: [{ text: combinedPrompt }] }],
        generationConfig: { temperature: 0.2, maxOutputTokens: maxTokens, responseMimeType: "application/json" },
      }),
      signal: AbortSignal.timeout(GEMINI_TIMEOUT),
    });
    if (res.status === 429) { console.warn("[ai] Gemini 429 (rate limit) — falling back"); return null; }
    const data = await res.json();
    const content = data?.candidates?.[0]?.content?.parts?.[0]?.text;
    return content;
  } catch (err) {
    if (err.name === "AbortError" || err.name === "TimeoutError") console.warn(`[ai] Gemini timeout (${GEMINI_TIMEOUT}ms)`);
    else console.error(`[ai] Gemini request failed: ${err.message}`);
    return null;
  }
}

// ── Unified AI chat: Gemini → Perplexity ──────────────────────────

// ── Unified AI chat: Gemini → Perplexity ─────────────────

async function aiChat(systemPrompt, userPrompt, maxTokens = 800) {
  const geminiResult = await geminiChat(systemPrompt, userPrompt, maxTokens);
  if (geminiResult) return { content: geminiResult, provider: "gemini", model: GEMINI_MODEL };
  const pplxResult = await pplxChat(systemPrompt, userPrompt, maxTokens);
  if (pplxResult) return { content: pplxResult, provider: "perplexity", model: PPLX_MODEL };
  return null;
}

function sleep(ms) { return new Promise((r) => setTimeout(r, ms)); }

// ── JSON extraction (string-aware brace matching) ────────────────

function extractJSON(raw) {
  if (typeof raw !== "string") return null;

  const start = raw.indexOf("{");
  if (start === -1) return null;

  let depth = 0;
  let inString = false;
  let escape = false;
  let end = -1;

  for (let i = start; i < raw.length; i++) {
    const ch = raw[i];
    if (escape) { escape = false; continue; }
    if (ch === "\\") { escape = true; continue; }
    if (ch === '"') { inString = !inString; continue; }
    if (inString) continue;
    if (ch === "{") depth++;
    else if (ch === "}") {
      depth--;
      if (depth === 0) { end = i; break; }
    }
  }

  if (end === -1) {
    console.warn("[ai] extractJSON: no balanced closing brace, raw starts with:", raw.slice(0, 120));
    return null;
  }

  const candidate = raw.slice(start, end + 1);
  try {
    return JSON.parse(candidate);
  } catch (e) {
    console.warn("[ai] extractJSON: JSON.parse failed:", e.message, "| snippet:", candidate.slice(0, 150));
    return null;
  }
}

function clamp(n, lo = 0, hi = 100) {
  const v = parseInt(n, 10);
  return isNaN(v) ? 50 : Math.max(lo, Math.min(hi, v));
}

function clampSigned(n, lo = -30, hi = 0) {
  const v = parseInt(n, 10);
  return isNaN(v) ? -10 : Math.max(lo, Math.min(hi, v));
}

// ── Validate & normalize AI output ───────────────────────────────

function validateFullScore(parsed, heuristic) {
  if (!parsed || typeof parsed !== "object") return null;
  const score = parseInt(parsed.score);
  if (isNaN(score)) return null;

  const heurBd = heuristic?.score_breakdown || {};

  let breakdown = null;
  if (parsed.score_breakdown && typeof parsed.score_breakdown === "object") {
    const bd = parsed.score_breakdown;
    breakdown = {
      breakout: clamp(bd.breakout ?? bd.breakout_strength ?? heurBd.breakout ?? 50),
      volume: clamp(bd.volume ?? bd.volume_confirmation ?? heurBd.volume ?? 50),
      oi: clamp(bd.oi ?? bd.oi_confirmation ?? heurBd.oi ?? 50),
      liquidity: clamp(bd.liquidity ?? bd.liquidity_quality ?? heurBd.liquidity ?? 50),
      funding: clamp(bd.funding ?? bd.funding_distortion ?? heurBd.funding ?? 50),
      regime: clamp(bd.regime ?? bd.market_regime ?? heurBd.regime ?? 50),
      provider: clamp(bd.provider ?? bd.provider_reliability ?? heurBd.provider ?? 60),
      risk_penalty: clampSigned(bd.risk_penalty ?? heurBd.risk_penalty ?? -10),
    };
  } else if (heurBd.breakout != null) {
    breakdown = { ...heurBd };
  }

  let tags = [];
  if (Array.isArray(parsed.tags)) {
    tags = parsed.tags
      .map((t) => String(t).toLowerCase().replace(/[\s_]/g, "-"))
      .filter((t) => SIGNAL_TAGS.includes(t))
      .slice(0, 4);
  }
  if (!tags.length && heuristic?.tags?.length) tags = heuristic.tags;

  let thesis = null;
  if (typeof parsed.thesis === "string" && parsed.thesis.length > 10) {
    thesis = parsed.thesis.slice(0, 500);
  } else if (heuristic?.thesis) {
    thesis = heuristic.thesis;
  }

  return {
    score: clamp(score),
    score_breakdown: breakdown,
    thesis,
    tags,
    regime: REGIMES.includes(parsed.regime) ? parsed.regime : (heuristic?.regime || "chop"),
    risk_flags: Array.isArray(parsed.risk_flags)
      ? parsed.risk_flags.filter((f) => typeof f === "string" && RISK_FLAGS.includes(f))
      : (heuristic?.risk_flags || []),
    reasoning: typeof parsed.reasoning === "string" ? parsed.reasoning.slice(0, 300) : (heuristic?.reasoning || ""),
  };
}

// ── Signal scoring ───────────────────────────────────────────────

const SYSTEM_PROMPT = `You are AgoraIQ's quantitative signal analyst. You score crypto trading signals based on market structure, volume dynamics, and risk metrics. Always respond with ONLY valid JSON, no markdown fences, no explanation outside the JSON.`;

async function scoreSignal(d) {
  const heuristic = fallbackScore(d);
  const userPrompt = buildScoringPrompt(d);
  const result = await aiChat(SYSTEM_PROMPT, userPrompt);

  if (!result) {
    console.warn(`[ai] All AI providers failed for ${d.symbol} — using heuristic`);
    return heuristic;
  }

  const parsed = extractJSON(result.content);
  if (!parsed) {
    console.warn(`[ai] Could not extract JSON for ${d.symbol} — using heuristic`);
    return heuristic;
  }

  const validated = validateFullScore(parsed, heuristic);
  if (!validated) {
    console.warn(`[ai] Validation failed for ${d.symbol} — using heuristic`);
    return heuristic;
  }

  return { ...validated, model: result.model, provider: result.provider };
}

function buildScoringPrompt(d) {
  const targets = (d.targets || []).map((t) => String(t)).join(", ") || "none";

  let rrNote = "";
  if (d.stop != null && d.stop > 0 && d.targets?.length) {
    const entry = parseFloat(d.entry) || 0;
    const stop = parseFloat(d.stop) || 0;
    const tp1 = parseFloat(d.targets[0]) || 0;
    if (entry && stop && tp1) {
      const risk = Math.abs(entry - stop);
      const reward = Math.abs(tp1 - entry);
      if (risk > 0) rrNote = `\n- Risk/Reward ratio: ${(reward / risk).toFixed(2)}`;
    }
  }

  return `Score this crypto signal from 0-100 and provide a detailed breakdown.

Signal:
- Symbol: ${d.symbol || "UNKNOWN"}
- Direction: ${d.direction || "LONG"}
- Entry: ${d.entry || "N/A"}
- Stop loss: ${d.stop || "none"}
- Take profit targets: ${targets}${rrNote}
- Leverage: ${d.leverage || "N/A"}
- Volume change (24h): ${d.volume_change || "N/A"}%
- Open interest direction: ${d.oi_direction || "N/A"}
- Funding rate: ${d.funding_rate || "N/A"}

Respond with ONLY this JSON, no other text:
{
  "score": <0-100 integer>,
  "score_breakdown": {
    "breakout": <0-100>,
    "volume": <0-100>,
    "oi": <0-100>,
    "liquidity": <0-100>,
    "funding": <0-100>,
    "regime": <0-100>,
    "provider": <0-100>,
    "risk_penalty": <-30 to 0>
  },
  "thesis": "<1-2 sentence trade rationale>",
  "tags": [<1-4 from: breakout, volume, trend, reversal, scalp, swing, high-risk, oi>],
  "regime": "<breakout|trend|chop|mean_reversion>",
  "risk_flags": [<from: crowded, thin_liquidity, extreme_funding, no_stop_loss, extreme_leverage, low_rr, high_leverage>],
  "reasoning": "<1 sentence>"
}`;
}

// ── Market regime classification ─────────────────────────────────

async function classifyRegime(m) {
  const systemPrompt = "You are a crypto market regime classifier. Respond with ONLY valid JSON.";
  const userPrompt = `Classify the current market regime for ${m.symbol}.

Market data:
- 1h change: ${m.price_1h}%
- 4h change: ${m.price_4h}%
- 24h change: ${m.price_24h}%
- Volume change: ${m.volume_change}%
- OI change: ${m.oi_change}%
- Funding rate: ${m.funding_rate}

Respond with ONLY:
{"regime": "<breakout|trend|chop|mean_reversion>", "confidence": <0-100>, "reasoning": "<1 sentence>"}`;

  const result = await aiChat(systemPrompt, userPrompt, 256);
  if (!result) return { regime: "chop", confidence: 50, reasoning: "AI unavailable" };

  const parsed = extractJSON(result.content);
  if (!parsed || !REGIMES.includes(parsed.regime)) {
    return { regime: "chop", confidence: 50, reasoning: "Parse error" };
  }

  return {
    regime: parsed.regime,
    confidence: typeof parsed.confidence === "number" ? clamp(parsed.confidence) : 50,
    reasoning: typeof parsed.reasoning === "string" ? parsed.reasoning.slice(0, 200) : "",
  };
}

// ── Heuristic fallback (structured) ──────────────────────────────

function fallbackScore(d) {
  let score = 45;
  const reasons = [];
  const flags = [];

  const entry = parseFloat(d.entry) || 0;
  const stop = parseFloat(d.stop) || 0;
  const tp1 = (d.targets || [])[0] ? parseFloat(d.targets[0]) : 0;
  const dir = (d.direction || "LONG").toUpperCase();
  const vol = parseFloat(d.volume_change) || 0;
  const lev = parseInt(d.leverage) || 0;
  const tpCount = (d.targets || []).length;

  let breakoutSub = 50;
  if (entry && tp1) {
    const pctMove = Math.abs(tp1 - entry) / entry;
    if (pctMove > 0.10) breakoutSub = 85;
    else if (pctMove > 0.05) breakoutSub = 70;
    else if (pctMove > 0.02) breakoutSub = 55;
    else breakoutSub = 35;
  }

  let volumeSub = 50;
  if (vol > 100) { volumeSub = 85; score += 10; reasons.push("high volume"); }
  else if (vol > 50) { volumeSub = 70; score += 5; }
  else if (vol > 20) { volumeSub = 55; }
  else { volumeSub = 40; }

  let oiSub = 50;
  if (d.oi_direction === "rising" && dir === "LONG") { oiSub = 75; score += 5; reasons.push("OI confirms"); }
  else if (d.oi_direction === "falling" && dir === "SHORT") { oiSub = 75; score += 5; reasons.push("OI confirms"); }
  else if (d.oi_direction) { oiSub = 35; }

  let liqSub = 50;
  if (vol > 80) liqSub = 70;
  else if (vol < 20) { liqSub = 30; flags.push("thin_liquidity"); }

  let fundingSub = 60;
  const fundingRate = parseFloat(d.funding_rate) || 0;
  if (Math.abs(fundingRate) > 0.05) { fundingSub = 40; flags.push("extreme_funding"); score += 3; }
  else if (Math.abs(fundingRate) > 0.02) { fundingSub = 55; }
  else { fundingSub = 70; }

  let regimeSub = 55;
  let regime = "chop";
  if (entry && tp1) {
    const pctMove = Math.abs(tp1 - entry) / entry;
    if (pctMove > 0.08) { regime = "breakout"; regimeSub = 75; }
    else if (pctMove > 0.03) { regime = "trend"; regimeSub = 65; }
    else { regime = "mean_reversion"; regimeSub = 50; }
  }

  let providerSub = 50;
  let riskPenalty = 0;

  if (entry && stop && tp1) {
    const risk = Math.abs(entry - stop);
    const reward = Math.abs(tp1 - entry);
    const rr = risk > 0 ? reward / risk : 0;
    if (rr >= 3) { providerSub += 25; score += 20; reasons.push("excellent R:R " + rr.toFixed(1)); }
    else if (rr >= 2) { providerSub += 18; score += 15; reasons.push("good R:R " + rr.toFixed(1)); }
    else if (rr >= 1.5) { providerSub += 10; score += 10; reasons.push("decent R:R " + rr.toFixed(1)); }
    else if (rr >= 1) { providerSub += 5; score += 5; reasons.push("marginal R:R " + rr.toFixed(1)); }
    else { score -= 5; riskPenalty -= 5; reasons.push("poor R:R " + rr.toFixed(1)); flags.push("low_rr"); }
  }

  if (tpCount >= 3) { providerSub += 10; score += 8; reasons.push(tpCount + " targets"); }
  else if (tpCount >= 2) { providerSub += 5; score += 5; reasons.push(tpCount + " targets"); }
  else if (tpCount === 1) { score += 3; }

  if (stop > 0) { providerSub += 8; score += 5; reasons.push("SL defined"); }
  else { riskPenalty -= 12; score -= 10; flags.push("no_stop_loss"); reasons.push("no SL"); }

  if (lev > 20) { riskPenalty -= 10; score -= 10; flags.push("extreme_leverage"); reasons.push(lev + "x leverage"); }
  else if (lev > 10) { riskPenalty -= 5; score -= 5; flags.push("high_leverage"); reasons.push(lev + "x leverage"); }
  else if (lev > 0 && lev <= 5) { score += 3; reasons.push("conservative " + lev + "x"); }

  providerSub = clamp(providerSub);

  const tags = [];
  if (breakoutSub >= 65) tags.push("breakout");
  if (volumeSub >= 65) tags.push("volume");
  if (dir === "LONG" && regime === "trend") tags.push("trend");
  if (dir === "SHORT" || regime === "mean_reversion") tags.push("reversal");
  if (oiSub >= 65) tags.push("oi");
  if (tpCount >= 3 || (entry && tp1 && Math.abs(tp1 - entry) / entry > 0.05)) tags.push("swing");
  else tags.push("scalp");
  if (riskPenalty <= -10 || flags.length >= 2) tags.push("high-risk");

  const dirWord = dir === "LONG" ? "Long" : "Short";
  const confLabel = score >= 80 ? "strong" : score >= 65 ? "moderate" : score >= 50 ? "speculative" : "weak";
  let thesis;
  if (dir === "LONG") {
    thesis = `${dirWord} setup on ${d.symbol || "this pair"} with ${confLabel} conviction. `;
    thesis += breakoutSub >= 65 ? "Price action shows breakout characteristics above consolidation. " : "Entry near support with anticipated upward continuation. ";
    if (volumeSub >= 65) thesis += "Volume profile confirms buyer interest. ";
    thesis += stop > 0 ? `Risk defined at ${d.stop} stop level.` : "No stop loss defined — elevated risk.";
  } else {
    thesis = `${dirWord} setup on ${d.symbol || "this pair"} with ${confLabel} conviction. `;
    thesis += breakoutSub >= 65 ? "Breakdown pattern below key support with momentum confirmation. " : "Rejection at resistance suggests distribution phase. ";
    if (volumeSub >= 65) thesis += "Sell-side volume supports directional bias. ";
    thesis += stop > 0 ? `Risk managed with stop at ${d.stop}.` : "No stop loss defined — elevated risk.";
  }

  return {
    score: clamp(score),
    score_breakdown: { breakout: breakoutSub, volume: volumeSub, oi: oiSub, liquidity: liqSub, funding: fundingSub, regime: regimeSub, provider: providerSub, risk_penalty: Math.max(-30, Math.min(0, riskPenalty)) },
    thesis: thesis.trim(),
    tags: [...new Set(tags)].slice(0, 4),
    regime,
    risk_flags: flags,
    reasoning: "Heuristic: " + (reasons.length ? reasons.join(", ") : "basic signal"),
    model: "heuristic-v3",
    provider: "local",
  };
}

module.exports = { scoreSignal, classifyRegime, fallbackScore, REGIMES, RISK_FLAGS, SIGNAL_TAGS };
